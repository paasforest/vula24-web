# PostgreSQL connection string (provided by Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server listens on (Railway sets this automatically)
PORT=3000

# Set to "production" on Railway
NODE_ENV=development

# Secret used for signing JWTs (future use)
JWT_SECRET=change-me-to-a-long-random-string

# Allowed CORS origin(s). Use "*" to allow all, or set to your Vercel domain.
# e.g. https://vula24.vercel.app
CORS_ORIGIN=*
