# Copy to .env.local and fill in real values (never commit .env.local)

# Required for Prisma (e.g. /api/requests, admin “Requests” tab). Homepage form posts to Railway by default.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
ADMIN_PASSWORD=
# Bearer token for Railway admin routes (PR #2). Same value as curl:
# curl -H "Authorization: Bearer …" https://…/api/admin/pending
# If unset, ADMIN_PASSWORD is used (keep them in sync if both are set).
VULA24_API_ADMIN_TOKEN=
# Public Railway API base (no trailing slash). Used by browser forms, locksmith UI, and server-side admin proxy.
NEXT_PUBLIC_VULA24_API_URL=https://vula24-api-production.up.railway.app

NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_PHONE_NUMBER=
NEXT_PUBLIC_EMAIL=

# Optional: locksmith dashboard URL (Log in tab on /for-locksmiths/account opens this)
NEXT_PUBLIC_LOCKSMITH_LOGIN_URL=

# Override if needed; defaults to vula24-production Railway in API route
LOCKSMITH_REGISTER_URL=

# Customer lead requests (website form)
JOBS_WEBSITE_REQUEST_URL=

# Banking details (activation SMS, locksmith payment pages)
BANK_NAME=
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_BRANCH_CODE=
BANK_ACCOUNT_TYPE=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMSPortal
SMSPORTAL_CLIENT_ID=
SMSPORTAL_CLIENT_SECRET=

# Google Search Console — paste the exact `content` from the HTML tag method (optional if file verification is enough)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# App
NEXT_PUBLIC_APP_URL=https://vula24.co.za

# Vercel cron (optional)
CRON_SECRET=
